{% set db = database | default('default') %}
{% set full_dict_name = db ~ '.' ~ dict_name %}
{% set key_columns = structure | selectattr('is_key', 'defined') | selectattr('is_key') | list %}

{% if description is defined and description %}
-- Description: {{ description }}
{% endif %}

CREATE DICTIONARY IF NOT EXISTS {{ full_dict_name | sql_safe }}
(
{% for col in structure %}
    {{ col.name | sql_safe }} {{ col.type }}
    {%- if col.is_key is defined and col.is_key %} IS KEY{% endif %}
    {%- if col.default is defined %} DEFAULT {{ col.default }}{% endif %}
    {%- if col.expression is defined %} EXPRESSION {{ col.expression }}{% endif %}
    {%- if col.hierarchical is defined and col.hierarchical %} HIERARCHICAL{% endif %}
    {%- if col.injective is defined and col.injective %} INJECTIVE{% endif %}
    {%- if not loop.last %},{% endif %}

{% endfor %}
)
PRIMARY KEY {{ key_columns | map(attribute='name') | join(', ') }}
SOURCE(
{% if source_type == 'clickhouse' %}
    CLICKHOUSE(
        HOST '{{ source_config.host | default('localhost') }}'
        PORT {{ source_config.port | default(9000) }}
        USER '{{ source_config.user | default('default') }}'
        {% if source_config.password is defined and source_config.password %}
        PASSWORD '{{ source_config.password }}'
        {% endif %}
        DB '{{ source_config.database }}'
        TABLE '{{ source_config.table }}'
        {% if source_config.where is defined and source_config.where %}
        WHERE {{ source_config.where }}
        {% endif %}
        {% if source_config.invalidate_query is defined and source_config.invalidate_query %}
        INVALIDATE_QUERY '{{ source_config.invalidate_query }}'
        {% endif %}
    )
{% elif source_type == 'postgresql' %}
    POSTGRESQL(
        HOST '{{ source_config.host }}'
        PORT {{ source_config.port | default(5432) }}
        USER '{{ source_config.user }}'
        PASSWORD '{{ source_config.password }}'
        DB '{{ source_config.database }}'
        TABLE '{{ source_config.table }}'
        {% if source_config.schema is defined and source_config.schema %}
        SCHEMA '{{ source_config.schema }}'
        {% endif %}
        {% if source_config.where is defined and source_config.where %}
        WHERE {{ source_config.where }}
        {% endif %}
        {% if source_config.invalidate_query is defined and source_config.invalidate_query %}
        INVALIDATE_QUERY '{{ source_config.invalidate_query }}'
        {% endif %}
    )
{% elif source_type == 'http' %}
    HTTP(
        URL '{{ source_config.url }}'
        FORMAT {{ source_config.format | default('JSONEachRow') }}
        {% if source_config.headers is defined and source_config.headers %}
        HEADERS(
        {% for key, value in source_config.headers.items() %}
            '{{ key }}' = '{{ value }}'{% if not loop.last %},{% endif %}

        {% endfor %}
        )
        {% endif %}
    )
{% elif source_type == 'file' %}
    FILE(
        PATH '{{ source_config.path }}'
        FORMAT {{ source_config.format | default('CSV') }}
    )
{% elif source_type == 'mysql' %}
    MYSQL(
        HOST '{{ source_config.host }}'
        PORT {{ source_config.port | default(3306) }}
        USER '{{ source_config.user }}'
        PASSWORD '{{ source_config.password }}'
        DB '{{ source_config.database }}'
        TABLE '{{ source_config.table }}'
        {% if source_config.where is defined and source_config.where %}
        WHERE {{ source_config.where }}
        {% endif %}
    )
{% elif source_type == 'odbc' %}
    ODBC(
        CONNECTION_STRING '{{ source_config.connection_string }}'
        TABLE '{{ source_config.table }}'
    )
{% endif %}
)
{% if layout == 'flat' %}
LAYOUT(FLAT(
    {% if layout_config is defined and layout_config.initial_array_size is defined %}
    INITIAL_ARRAY_SIZE {{ layout_config.initial_array_size }}
    {% endif %}
    {% if layout_config is defined and layout_config.max_array_size is defined %}
    MAX_ARRAY_SIZE {{ layout_config.max_array_size }}
    {% endif %}
))
{% elif layout == 'hashed' %}
LAYOUT(HASHED(
    {% if layout_config is defined and layout_config.shards is defined %}
    SHARDS {{ layout_config.shards }}
    {% endif %}
))
{% elif layout == 'sparse_hashed' %}
LAYOUT(SPARSE_HASHED())
{% elif layout == 'complex_key_hashed' %}
LAYOUT(COMPLEX_KEY_HASHED(
    {% if layout_config is defined and layout_config.shards is defined %}
    SHARDS {{ layout_config.shards }}
    {% endif %}
))
{% elif layout == 'complex_key_sparse_hashed' %}
LAYOUT(COMPLEX_KEY_SPARSE_HASHED())
{% elif layout == 'range_hashed' %}
LAYOUT(RANGE_HASHED(
    {% if layout_config is defined and layout_config.range_lookup_strategy is defined %}
    RANGE_LOOKUP_STRATEGY {{ layout_config.range_lookup_strategy }}
    {% endif %}
))
{% elif layout == 'cache' %}
LAYOUT(CACHE(
    SIZE_IN_CELLS {{ layout_config.size_in_cells | default(100000) }}
))
{% elif layout == 'complex_key_cache' %}
LAYOUT(COMPLEX_KEY_CACHE(
    SIZE_IN_CELLS {{ layout_config.size_in_cells | default(100000) }}
))
{% elif layout == 'ssd_cache' %}
LAYOUT(SSD_CACHE(
    BLOCK_SIZE {{ layout_config.block_size | default(4096) }}
    FILE_SIZE {{ layout_config.file_size | default(16106127360) }}
    READ_BUFFER_SIZE {{ layout_config.read_buffer_size | default(131072) }}
    WRITE_BUFFER_SIZE {{ layout_config.write_buffer_size | default(1048576) }}
    PATH '{{ layout_config.path }}'
))
{% elif layout == 'direct' %}
LAYOUT(DIRECT())
{% elif layout == 'ip_trie' %}
LAYOUT(IP_TRIE())
{% else %}
LAYOUT({{ layout | upper }}())
{% endif %}
{% if lifetime is defined and lifetime %}
LIFETIME(MIN {{ lifetime.min | default(300) }} MAX {{ lifetime.max | default(600) }})
{% else %}
LIFETIME(MIN 300 MAX 600)
{% endif %}
{% if comment is defined and comment %}
COMMENT '{{ comment | sql_escape }}'
{% endif %}
;
