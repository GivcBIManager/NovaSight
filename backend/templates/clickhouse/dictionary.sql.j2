-- ============================================================================
-- NovaSight Generated ClickHouse Dictionary: {{ dict_name }}
-- Generated: {{ _generated_at | default(now().isoformat()) }}
-- Template: clickhouse/dictionary.sql.j2 v{{ _template_version | default('1.0.0') }}
-- WARNING: Auto-generated file - do not edit manually
