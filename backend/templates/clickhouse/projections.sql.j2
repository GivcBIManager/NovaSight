-- Projection Usage Notes
-- =============================================================================
/*
To verify projection usage in queries, use:
    EXPLAIN indexes = 1 SELECT ... FROM {{ full_table_name }} WHERE ...

To check projection storage:
    SELECT 
        name,
        formatReadableSize(sum(data_compressed_bytes)) as compressed,
        formatReadableSize(sum(data_uncompressed_bytes)) as uncompressed
    FROM system.projection_parts
    WHERE database = '{{ db }}' AND table = '{{ table_name }}'
    GROUP BY name;

To drop a projection:
    ALTER TABLE {{ full_table_name }} DROP PROJECTION <projection_name>;

To clear projection data (keeps definition):
    ALTER TABLE {{ full_table_name }} CLEAR PROJECTION <projection_name>;
*/
