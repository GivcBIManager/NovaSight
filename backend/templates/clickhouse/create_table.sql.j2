{% set db = database | default('default') %}
{% set full_table_name = db ~ '.' ~ table_name %}

CREATE TABLE IF NOT EXISTS {{ full_table_name }}
(
{% if tenant_aware | default(true) %}
    -- Tenant isolation column
    tenant_id UUID,
{% endif %}
{% for column in columns %}
    {{ column.name }} {% if column.nullable | default(false) %}Nullable({{ column.type }}){% else %}{{ column.type }}{% endif %}{% if column.default is defined and column.default %} DEFAULT {{ column.default }}{% endif %}{% if column.codec is defined and column.codec %} CODEC({{ column.codec }}){% endif %}{% if column.ttl is defined and column.ttl %} TTL {{ column.ttl }}{% endif %}{% if not loop.last %},{% endif %}

