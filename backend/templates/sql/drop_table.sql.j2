-- ============================================================================
-- NovaSight Drop Table: {{ table_name }}
-- Generated: {{ _generated_at | default(now().isoformat()) }}
-- Template: sql/drop_table.sql.j2 v{{ _template_version | default('1.0.0') }}
-- WARNING: Auto-generated file - do not edit manually
