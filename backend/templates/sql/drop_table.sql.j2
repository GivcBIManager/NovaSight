{% set schema = schema_name | default('public') %}
{% set full_table_name = schema ~ '.' ~ (table_name | sql_safe) %}

-- Drop associated trigger first (if exists)
DROP TRIGGER IF EXISTS update_{{ table_name }}_updated_at ON {{ full_table_name }};

-- Drop RLS policies (if any)
{% if tenant_aware | default(true) %}
DROP POLICY IF EXISTS {{ table_name }}_tenant_isolation_policy ON {{ full_table_name }};
{% endif %}

-- Drop the table
DROP TABLE {% if if_exists | default(true) %}IF EXISTS {% endif %}{{ full_table_name }}{% if cascade | default(false) %} CASCADE{% endif %};
