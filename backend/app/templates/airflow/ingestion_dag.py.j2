    'execution_timeout': timedelta(hours={{ execution_timeout_hours | default(2) }}),
}

with DAG(
    dag_id='ingest_{{ tenant_id }}_{{ datasource_id }}',
    description='Ingest data from {{ datasource_type }} for tenant {{ tenant_id }}',
    schedule='{{ schedule | default("@daily") }}',
    start_date=datetime({{ start_date | default('2024-01-01') | replace('-', ', ') }}),
    catchup={{ catchup | default(false) | lower | capitalize }},
    default_args=default_args,
    tags=['ingestion', 'tenant_{{ tenant_id }}', '{{ datasource_type }}'],
    max_active_runs={{ max_active_runs | default(1) }},
) as dag:
    
    # Start marker
    start = EmptyOperator(task_id='start')
    
    # Check source availability
    check_source = SourceAvailabilitySensor(
        task_id='check_source',
        connection_id='{{ connection_id }}',
        timeout={{ source_check_timeout | default(300) }},
        poke_interval={{ source_check_poke_interval | default(30) }},
        mode='reschedule',
    )
    
    # Ingest each table in a TaskGroup
    with TaskGroup('ingest_tables', tooltip='Ingest all configured tables') as ingest_group:
{% for mapping in table_mappings %}
        ingest_{{ mapping.target_table | replace('.', '_') }} = IngestTableOperator(
            task_id='ingest_{{ mapping.target_table | replace('.', '_') }}',
            connection_id='{{ connection_id }}',
            source_schema='{{ mapping.source_schema | default('') }}',
            source_table='{{ mapping.source_table }}',
            target_schema='{{ mapping.target_schema | default('raw') }}',
            target_table='{{ mapping.target_table }}',
            tenant_id='{{ tenant_id }}',
            incremental_column='{{ mapping.incremental_column | default('updated_at') }}',
            mode='{{ mapping.mode | default('incremental') }}',
{% if mapping.primary_keys is defined and mapping.primary_keys | length > 0 %}
            primary_keys={{ mapping.primary_keys | tojson }},
{% endif %}
{% if mapping.columns is defined and mapping.columns | length > 0 %}
            columns={{ mapping.columns | tojson }},
{% endif %}
{% if mapping.where_clause is defined and mapping.where_clause %}
            where_clause='{{ mapping.where_clause | replace("'", "\\'") }}',
{% endif %}
            batch_size={{ mapping.batch_size | default(100000) }},
        )
{% endfor %}
    
    # Validate ingested data
    validate_data = DataValidationOperator(
        task_id='validate_data',
        tenant_id='{{ tenant_id }}',
        tables={{ table_mappings | map(attribute='target_table') | list | tojson }},
        validation_rules=[
            'row_count_check',
            'null_check',
            'freshness_check',
        ],
        trigger_rule=TriggerRule.ALL_SUCCESS,
    )
    
{% if notify_on_success | default(false) %}
    # Success notification
    from airflow.operators.email import EmailOperator
    notify_success = EmailOperator(
        task_id='notify_success',
