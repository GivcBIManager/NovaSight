{# 
NovaSight DAG Template
======================

This template generates Airflow DAG Python files from validated configurations.
All code is generated from pre-approved templates - no arbitrary code execution.

Template Variables:
- dag_id: Full DAG identifier (tenant-prefixed)
- description: DAG description
- schedule: Schedule string (CRON, preset, or None)
- start_date: Start date as datetime constructor
- catchup: Enable catchup boolean
- max_active_runs: Maximum active runs
- default_args: Default task arguments
- tags: List of tags
- tasks: List of task configurations
- generated_at: Generation timestamp
- version: Configuration version
#}
"""
Auto-generated NovaSight DAG
============================

DAG ID: {{ dag_id }}
Version: {{ version }}
Generated: {{ generated_at }}
Owner: {{ owner | default(tenant_name, true) | default('novasight', true) }}

WARNING: This file is auto-generated by NovaSight.
Do not edit manually - changes will be overwritten.
"""
from __future__ import annotations

from datetime import datetime, timedelta
import pendulum
from airflow.models.dag import DAG
from airflow.operators.python import PythonOperator
from airflow.operators.bash import BashOperator
from airflow.providers.smtp.operators.smtp import EmailOperator
from airflow.providers.http.sensors.http import HttpSensor
from airflow.sensors.time_sensor import TimeSensor
from airflow.providers.apache.spark.operators.spark_submit import SparkSubmitOperator
from airflow.utils.trigger_rule import TriggerRule


# Default arguments for all tasks
default_args = {
    'owner': '{{ owner | default(tenant_name, true) | default("novasight", true) }}',
    'depends_on_past': False,
    'retries': {{ default_args.retries }},
    'retry_delay': timedelta(minutes={{ default_args.retry_delay_minutes }}),
    {% if default_args.email %}
    'email': {{ default_args.email | tojson }},
    'email_on_failure': {{ default_args.email_on_failure | lower }},
    'email_on_success': {{ default_args.email_on_success | lower }},
    {% else %}
    'email_on_failure': False,
    'email_on_success': False,
    {% endif %}
}

# DAG Definition
with DAG(
    dag_id='{{ dag_id }}',
    description='{{ description | replace("'", "\\'") }}',
    default_args=default_args,
    schedule={{ schedule }},
    start_date=pendulum.datetime({{ start_date_year | default(2024) }}, {{ start_date_month | default(1) }}, {{ start_date_day | default(1) }}, tz='{{ timezone | default("UTC") }}'),
    catchup={{ catchup | lower | capitalize }},
    max_active_runs={{ max_active_runs }},
    tags={{ tags | tojson }},
) as dag:
    
    # Task definitions
    tasks = {}
    
    {% for task in tasks %}
    # Task: {{ task.task_id }}
    {% if task.task_type == 'spark_submit' %}
    tasks['{{ task.task_id }}'] = SparkSubmitOperator(
        task_id='{{ task.task_id }}',
        application='{{ task.config.get("application_path") or task.config.get("application", "/opt/spark/jobs/ingestion.py") }}',
        conf={
            'spark.executor.memory': '{{ task.config.get("executor_memory", "2g") }}',
            'spark.executor.cores': '{{ task.config.get("executor_cores", 2) }}',
        },
        application_args=[
            '--job-id', '{{ task.config.get("ingestion_job_id", "") }}',
        ],
        execution_timeout=timedelta(minutes={{ task.timeout_minutes }}),
        retries={{ task.retries }},
        retry_delay=timedelta(minutes={{ task.retry_delay_minutes }}),
        trigger_rule=TriggerRule.{{ task.trigger_rule | upper }},
    )
    {% elif task.task_type == 'dbt_run' %}
    tasks['{{ task.task_id }}'] = BashOperator(
        task_id='{{ task.task_id }}',
        bash_command='cd /opt/dbt && dbt run {% if task.config.get("models") %}--models {{ task.config.models | join(" ") }}{% endif %} {% if task.config.get("full_refresh") %}--full-refresh{% endif %}',
        execution_timeout=timedelta(minutes={{ task.timeout_minutes }}),
        retries={{ task.retries }},
        retry_delay=timedelta(minutes={{ task.retry_delay_minutes }}),
        trigger_rule=TriggerRule.{{ task.trigger_rule | upper }},
    )
    {% elif task.task_type == 'dbt_test' %}
    tasks['{{ task.task_id }}'] = BashOperator(
        task_id='{{ task.task_id }}',
        bash_command='cd /opt/dbt && dbt test {% if task.config.get("models") %}--models {{ task.config.models | join(" ") }}{% endif %}',
        execution_timeout=timedelta(minutes={{ task.timeout_minutes }}),
        retries={{ task.retries }},
        retry_delay=timedelta(minutes={{ task.retry_delay_minutes }}),
        trigger_rule=TriggerRule.{{ task.trigger_rule | upper }},
    )
    {% elif task.task_type == 'email' %}
    tasks['{{ task.task_id }}'] = EmailOperator(
        task_id='{{ task.task_id }}',
        to={{ task.config.get("recipients", []) | tojson }},
        subject='{{ task.config.get("subject", "NovaSight Notification") | replace("'", "\\'") }}',
        html_content='{{ task.config.get("body_template", "") | replace("'", "\\'") }}',
        trigger_rule=TriggerRule.{{ task.trigger_rule | upper }},
    )
    {% elif task.task_type == 'http_sensor' %}
    tasks['{{ task.task_id }}'] = HttpSensor(
        task_id='{{ task.task_id }}',
        http_conn_id='{{ task.config.get("connection_id", "http_default") }}',
        endpoint='{{ task.config.get("endpoint", "/") }}',
        method='{{ task.config.get("method", "GET") }}',
        response_check=lambda response: response.status_code == {{ task.config.get("expected_status", 200) }},
        poke_interval={{ task.config.get("poke_interval_seconds", 60) }},
        timeout={{ task.timeout_minutes * 60 }},
        trigger_rule=TriggerRule.{{ task.trigger_rule | upper }},
    )
    {% elif task.task_type == 'bash_operator' %}
    tasks['{{ task.task_id }}'] = BashOperator(
        task_id='{{ task.task_id }}',
        bash_command='{{ task.config.get("command", "echo Hello") | replace("'", "\\'") }}',
        execution_timeout=timedelta(minutes={{ task.timeout_minutes }}),
        retries={{ task.retries }},
        retry_delay=timedelta(minutes={{ task.retry_delay_minutes }}),
        trigger_rule=TriggerRule.{{ task.trigger_rule | upper }},
    )
    {% else %}
    # Default Python operator for task type: {{ task.task_type }}
    tasks['{{ task.task_id }}'] = PythonOperator(
        task_id='{{ task.task_id }}',
        python_callable=lambda: print('Task {{ task.task_id }} executed'),
        execution_timeout=timedelta(minutes={{ task.timeout_minutes }}),
        retries={{ task.retries }},
        retry_delay=timedelta(minutes={{ task.retry_delay_minutes }}),
        trigger_rule=TriggerRule.{{ task.trigger_rule | upper }},
    )
    {% endif %}
    
    {% endfor %}
    
    # Define task dependencies
    {% for task in tasks %}
    {% if task.depends_on %}
    {% for dep in task.depends_on %}
    tasks['{{ dep }}'] >> tasks['{{ task.task_id }}']
    {% endfor %}
    {% endif %}
    {% endfor %}
