{#
Run dbt source freshness check
#}
{% macro dbt_freshness(
    task_id='check_source_freshness',
    select=none,
    project_dir='DBT_PROJECT_DIR',
    profiles_dir='DBT_PROFILES_DIR',
    timeout_minutes=15,
    trigger_rule='all_success'
) %}
    {{ task_id }} = BashOperator(
        task_id='{{ task_id }}',
        bash_command=f'''
            set -e
            cd {{ '{' }}{{ project_dir }}{{ '}' }} && \
            dbt source freshness --profiles-dir {{ '{' }}{{ profiles_dir }}{{ '}' }} \
{% if select %}
                --select {{ select }} \
{% endif %}

        ''',
        execution_timeout=timedelta(minutes={{ timeout_minutes }}),
        trigger_rule=TriggerRule.{{ trigger_rule | upper }},
    )
{% endmacro %}
