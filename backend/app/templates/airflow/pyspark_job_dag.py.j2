"""
Auto-generated Airflow DAG for PySpark Application: {{ pyspark_app_name }}
Generated for tenant: {{ tenant_id }}
Tenant Database: {{ tenant_database }}
PySpark App ID: {{ pyspark_app_id }}
Generated at: {{ generated_at }}
Owner: {{ tenant_slug | default(tenant_id, true) | default('novasight', true) }}

This DAG runs a pre-defined PySpark job created via the PySpark App Builder.
The PySpark code was generated from approved templates (ADR-002 compliant).
Data is written to tenant-isolated ClickHouse database (ADR-003 compliant).

Spark submission: Uses native SparkSubmitOperator (preferred) or docker exec fallback.
"""
from __future__ import annotations

import os
from datetime import datetime, timedelta
import pendulum
from airflow.models.dag import DAG
from airflow.operators.bash import BashOperator
from airflow.operators.python import PythonOperator
from airflow.providers.apache.spark.operators.spark_submit import SparkSubmitOperator

# Tenant isolation context
TENANT_ID = '{{ tenant_id }}'
TENANT_SLUG = '{{ tenant_slug | default(tenant_id, true) }}'
TENANT_DATABASE = '{{ tenant_database | default("tenant_" ~ tenant_slug, true) }}'

# ============================================
# Spark Configuration
# ============================================
SPARK_HOME = os.environ.get('SPARK_HOME', '/opt/spark')
SPARK_MASTER = os.environ.get('SPARK_MASTER', 'spark://spark-master:7077')
SPARK_MASTER_CONTAINER = os.environ.get('SPARK_MASTER_CONTAINER', 'novasight-spark-master')

# Check if native Spark is available (preferred)
SPARK_NATIVE_AVAILABLE = os.path.exists(f'{SPARK_HOME}/bin/spark-submit')

# JDBC JARs for database connectivity
JDBC_JARS = ','.join([
    f'{SPARK_HOME}/jars/custom/postgresql-42.7.4.jar',
    f'{SPARK_HOME}/jars/custom/clickhouse-jdbc-0.6.3.jar',
])

# Default arguments for the DAG
default_args = {
    'owner': '{{ tenant_slug | default(tenant_id, true) | default("novasight", true) }}',
    'depends_on_past': False,
    'start_date': pendulum.datetime(2024, 1, 1, tz='{{ timezone | default("UTC") }}'),
    'email_on_failure': {{ 'True' if notifications.get('email_on_failure') else 'False' }},
    'email_on_retry': False,
    'retries': {{ retries | default(2) }},
    'retry_delay': timedelta(minutes={{ retry_delay_minutes | default(5) }}),
    {% if notifications.get('email') %}
    'email': ['{{ notifications.email }}'],
    {% endif %}
}

# DAG definition
with DAG(
    dag_id='{{ dag_id }}',
    default_args=default_args,
    description='{{ pyspark_app_description | default("PySpark data pipeline", true) }}',
    schedule='{{ schedule }}',
    catchup=False,
    max_active_runs=1,
    tags=[
        'pyspark',
        'tenant_{{ tenant_slug | default(tenant_id, true) }}',
        '{{ scd_type }}',
        '{{ write_mode }}',
        {% if source_type %}'source_{{ source_type }}',{% endif %}
    ],
) as dag:
    
    # PySpark job task with hybrid execution (native or docker fallback)
    if SPARK_NATIVE_AVAILABLE:
        # Use native SparkSubmitOperator (preferred)
        run_pyspark_job = SparkSubmitOperator(
            task_id='run_{{ pyspark_app_name | lower | replace(" ", "_") | replace("-", "_") }}',
            application='{{ spark_app_path }}',
            conn_id='spark_default',
            jars=JDBC_JARS,
            executor_memory='{{ spark_conf.get("spark.executor.memory", "2g") }}',
            executor_cores={{ spark_conf.get("spark.executor.cores", 2) }},
            driver_memory='{{ spark_conf.get("spark.driver.memory", "1g") }}',
            conf={
                {% for key, value in spark_conf.items() %}
                '{{ key }}': '{{ value }}',
                {% endfor %}
                'spark.app.tenant_id': TENANT_ID,
                'spark.app.tenant_database': TENANT_DATABASE,
            },
            env_vars={
                'TENANT_ID': TENANT_ID,
                'TENANT_DATABASE': TENANT_DATABASE,
                'TARGET_DATABASE': '{{ target_database }}',
            },
        )
    else:
        # Fallback to docker exec
        SPARK_SUBMIT_CMD = f"""
docker exec {SPARK_MASTER_CONTAINER} /opt/spark/bin/spark-submit \\
    --master spark://spark-master:7077 \\
    --deploy-mode client \\
    --driver-memory {{ spark_conf.get('spark.driver.memory', '1g') }} \\
    --executor-memory {{ spark_conf.get('spark.executor.memory', '2g') }} \\
    --executor-cores {{ spark_conf.get('spark.executor.cores', '2') }} \\
    --jars /opt/spark/jars/custom/postgresql-42.7.4.jar,/opt/spark/jars/custom/clickhouse-jdbc-0.6.3.jar \\
    {% for key, value in spark_conf.items() %}
    --conf "{{ key }}={{ value }}" \\
    {% endfor %}
    --conf "spark.app.tenant_id={TENANT_ID}" \\
    --conf "spark.app.tenant_database={TENANT_DATABASE}" \\
    {{ spark_app_path }}
"""
        run_pyspark_job = BashOperator(
            task_id='run_{{ pyspark_app_name | lower | replace(" ", "_") | replace("-", "_") }}',
            bash_command=SPARK_SUBMIT_CMD,
            env={
                'TENANT_ID': TENANT_ID,
                'TENANT_DATABASE': TENANT_DATABASE,
                'TARGET_DATABASE': '{{ target_database }}',
            },
        )
    
    def log_completion(**context):
        """Log completion of PySpark job."""
        ti = context['ti']
        print(f"PySpark job completed: {{ pyspark_app_name }}")
        print(f"Tenant: {TENANT_SLUG} (Database: {TENANT_DATABASE})")
        print(f"Target: {{ target_database }}.{{ target_table }}")
        print(f"SCD Type: {{ scd_type }}, Write Mode: {{ write_mode }}")
        print(f"Template Version: {{ template_version }}")
        print(f"Spark Mode: {'Native SparkSubmitOperator' if SPARK_NATIVE_AVAILABLE else 'Docker exec fallback'}")
    
    log_task = PythonOperator(
        task_id='log_completion',
        python_callable=log_completion,
    )
    
    # Task dependencies
    run_pyspark_job >> log_task

