{# 
NovaSight DAG Template (Refactored)
===================================

This template generates Airflow DAG Python files from validated configurations.
All code is generated from pre-approved templates - no arbitrary code execution.

Uses modular components from components/ directory for cleaner, DRY code.

Template Variables:
- dag_id: Full DAG identifier (tenant-prefixed)
- description: DAG description
- schedule: Schedule string (CRON, preset, or None)
- start_date_year, start_date_month, start_date_day: Start date components
- catchup: Enable catchup boolean
- max_active_runs: Maximum active runs
- default_args: Default task arguments
- tags: List of tags
- tasks: List of task configurations
- generated_at: Generation timestamp
- version: Configuration version
- tenant_id: Tenant identifier (optional)
#}
{% from 'components/base.py.j2' import header, imports, spark_config, default_args as default_args_macro, tenant_context %}
{% from 'components/spark.py.j2' import spark_submit_hybrid, spark_task_from_config %}
{% from 'components/dbt.py.j2' import dbt_run, dbt_test %}
{% from 'components/tasks.py.j2' import email_task, http_sensor_task, bash_task, log_completion_task %}

{{ header(dag_id, version, owner | default(tenant_name, true) | default('novasight', true), description) }}

{{ imports(use_spark=true, use_email=true, use_http_sensor=true) }}

{{ spark_config() }}

{% if tenant_id %}
{{ tenant_context(tenant_id, tenant_slug, tenant_database) }}
{% endif %}

{{ default_args_macro(
    owner=owner | default(tenant_name, true) | default('novasight', true),
    retries=default_args.retries,
    retry_delay_minutes=default_args.retry_delay_minutes,
    email=default_args.email,
    email_on_failure=default_args.email_on_failure,
    email_on_success=default_args.email_on_success
) }}

# DAG Definition
with DAG(
    dag_id='{{ dag_id }}',
    description='{{ description | replace("'", "\\'") }}',
    default_args=default_args,
    schedule={{ schedule }},
    start_date=pendulum.datetime({{ start_date_year | default(2024) }}, {{ start_date_month | default(1) }}, {{ start_date_day | default(1) }}, tz='{{ timezone | default("UTC") }}'),
    catchup={{ catchup | lower | capitalize }},
    max_active_runs={{ max_active_runs }},
    tags={{ tags | tojson }},
) as dag:
    
    # Task definitions
    tasks = {}
    
    {% for task in tasks %}
    # Task: {{ task.task_id }}
    {% if task.task_type == 'spark_submit' %}
    # Spark Submit Task
{{ spark_submit_hybrid(
    task_id=task.task_id,
    application=task.config.get('application_path') or task.config.get('application', '/opt/spark/jobs/job.py'),
    executor_memory=task.config.get('executor_memory', '2g'),
    executor_cores=task.config.get('executor_cores', 2),
    driver_memory=task.config.get('driver_memory', '1g'),
    spark_conf=task.config.get('spark_conf'),
    timeout_minutes=task.timeout_minutes,
    retries=task.retries,
    retry_delay_minutes=task.retry_delay_minutes,
    trigger_rule=task.trigger_rule
) }}
    tasks['{{ task.task_id }}'] = {{ task.task_id }}
    {% elif task.task_type == 'dbt_run' %}
    # dbt Run Task
{{ dbt_run(
    task_id=task.task_id,
    models=task.config.get('models'),
    select=task.config.get('select'),
    full_refresh=task.config.get('full_refresh', false),
    timeout_minutes=task.timeout_minutes,
    retries=task.retries,
    retry_delay_minutes=task.retry_delay_minutes,
    trigger_rule=task.trigger_rule
) }}
    tasks['{{ task.task_id }}'] = {{ task.task_id }}
    {% elif task.task_type == 'dbt_test' %}
    # dbt Test Task
{{ dbt_test(
    task_id=task.task_id,
    models=task.config.get('models'),
    select=task.config.get('select'),
    timeout_minutes=task.timeout_minutes,
    retries=task.retries,
    retry_delay_minutes=task.retry_delay_minutes,
    trigger_rule=task.trigger_rule
) }}
    tasks['{{ task.task_id }}'] = {{ task.task_id }}
    {% elif task.task_type == 'email' %}
    # Email Task
{{ email_task(
    task_id=task.task_id,
    recipients=task.config.get('recipients', []),
    subject=task.config.get('subject', 'NovaSight Notification'),
    html_content=task.config.get('body_template', ''),
    trigger_rule=task.trigger_rule
) }}
    tasks['{{ task.task_id }}'] = {{ task.task_id }}
    {% elif task.task_type == 'http_sensor' %}
    # HTTP Sensor Task
{{ http_sensor_task(
    task_id=task.task_id,
    connection_id=task.config.get('connection_id', 'http_default'),
    endpoint=task.config.get('endpoint', '/'),
    method=task.config.get('method', 'GET'),
    expected_status=task.config.get('expected_status', 200),
    poke_interval_seconds=task.config.get('poke_interval_seconds', 60),
    timeout_seconds=task.timeout_minutes * 60,
    trigger_rule=task.trigger_rule
) }}
    tasks['{{ task.task_id }}'] = {{ task.task_id }}
    {% elif task.task_type == 'bash_operator' %}
    # Bash Task
{{ bash_task(
    task_id=task.task_id,
    command=task.config.get('command', 'echo Hello'),
    timeout_minutes=task.timeout_minutes,
    retries=task.retries,
    retry_delay_minutes=task.retry_delay_minutes,
    trigger_rule=task.trigger_rule
) }}
    tasks['{{ task.task_id }}'] = {{ task.task_id }}
    {% else %}
    # Default Python operator for task type: {{ task.task_type }}
    tasks['{{ task.task_id }}'] = PythonOperator(
        task_id='{{ task.task_id }}',
        python_callable=lambda: print('Task {{ task.task_id }} executed'),
        execution_timeout=timedelta(minutes={{ task.timeout_minutes }}),
        retries={{ task.retries }},
        retry_delay=timedelta(minutes={{ task.retry_delay_minutes }}),
        trigger_rule=TriggerRule.{{ task.trigger_rule | upper }},
    )
    {% endif %}
    
    {% endfor %}
    
    # Define task dependencies
    {% for task in tasks %}
    {% if task.depends_on %}
    {% for dep in task.depends_on %}
    tasks['{{ dep }}'] >> tasks['{{ task.task_id }}']
    {% endfor %}
    {% endif %}
    {% endfor %}
